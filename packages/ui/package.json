{
  "name": "@valencets/ui",
  "version": "0.3.3",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens/primitives.css": "./dist/tokens/primitives.css",
    "./tokens/semantic.css": "./dist/tokens/semantic.css",
    "./tailwind": {
      "import": "./dist/tailwind/index.js",
      "types": "./dist/tailwind/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && cp src/tokens/*.css dist/tokens/",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/valencets/valence.git",
    "directory": "packages/ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@storybook/web-components": "^10.3.1",
    "@storybook/web-components-vite": "^10.3.1",
    "happy-dom": "^20.8.8",
    "lit": "^3.3.2",
    "storybook": "^10.3.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "tailwindcss": ">=3.4.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  },
  "homepage": "https://github.com/valencets/valence/tree/master/packages/ui#readme",
  "bugs": {
    "url": "https://github.com/valencets/valence/issues"
  },
  "sideEffects": [
    "./dist/components/register.js"
  ]
}
